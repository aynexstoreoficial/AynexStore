@{
    ViewData["Title"] = "Inicio";
}


<!-- Ventajas -->
<section class="ventajas">
    <div class="ventaja-item-envio">📦 Envíos Rápidos</div>
    <div class="ventaja-item-calidad">✅ Calidad Garantizada</div>
    <div class="ventaja-item-atencion">💬 Atención Personalizada</div>
</section>

<!-- Productos Destacados -->
<section class="productos" id="productos">
    <h2>Nuestros Productos Destacados</h2>
    <div class="productos-grid">
        <div class="producto-card">
            <div class="producto-imagen">
                <img src="~/imagen/TrapoCoffeBreakTodosPaños-PresentacionDeTodo.jpeg" alt="Pack Trapos de Cocina">
            </div>
            <h3>Pack Trapos de Cocina</h3>
            <a href="/Producto/Detalle/1" class="btn-link">VER MÁS</a><!-- id=1 -->
        </div>
        <div class="producto-card">
            <div class="producto-imagen">
                <img src="~/imagen/Captura4.PNG" alt="Paños Multiusos">
            </div>
            <h3>Paños Multiusos</h3>
            <a href="/Producto/Detalle/2" class="btn-link">VER MÁS</a>  <!-- id=2 -->
        </div>
        <div class="producto-card">
            <div class="producto-imagen">
                <img src="~/imagen/Captura1.PNG" alt="Esponjas de Limpieza">
            </div>
            <h3>Esponjas de Limpieza</h3>
            <a href="/Producto/Detalle/3" class="btn-link">VER MÁS</a>  <!-- id=3 -->
        </div>
    </div>
</section>

<!-- Sobre Aynex Store -->
<section class="sobre-nosotros" id="sobre-aynex">
    <div class="sobre-container">
        <div class="sobre-texto">
            <h2>Sobre Aynex Store</h2>
            <h3>Comprometidos con tu hogar</h3>
            <p>En Aynex Store ofrecemos productos de alta calidad para hacer tu hogar más fácil y eficiente. Descubre más sobre nosotros.</p>
            <button class="btn-light">Leer Más ></button>
        </div>
        <div class="sobre-imagen">
            <img src="~/imagen/FotoPrueba.PNG" alt="Sobre Aynex Store">
        </div>
    </div>
</section>

<!-- Compra Fácil y Rápida -->
<section class="compra-rapida" id="contacto">
    <h2>Compra Fácil y Rápida</h2>
    <div class="botones-container">      
        <a href="https://wa.me/34632990531" class="btn-wa" target="_blank">
            <i class="bi bi-whatsapp"></i> Pedir por WhatsApp
        </a>
        <a href="tel:+34632990531" class="btn-call">
            <i class="bi bi-telephone"></i> Llamar Ahora
        </a>
    </div>
</section>

